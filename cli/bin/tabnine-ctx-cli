#!/usr/bin/env bash
# Wrapper for tabnine-ctx-cli.
#
# Adds:  tabnine-ctx-cli install --type <core|full>
# Delegates everything else to the engine binary (tabnine-ctx-cli-engine).

set -euo pipefail

# ── Load ctx-settings.yaml into env (same logic as install.sh wrapper) ──
settings_file="${PWD}/ctx-settings.yaml"
[ ! -f "$settings_file" ] && settings_file="${PWD}/.tabnine/ctx/ctx-settings.yaml"
if [ -f "$settings_file" ]; then
  while IFS=': ' read -r key value; do
    case "$key" in \#*|"") continue ;; esac
    [ -z "$value" ] && continue
    if [ -z "${!key:-}" ]; then
      export "$key=$value"
    fi
  done < "$settings_file"
fi

# ── Handle `install` subcommand ──────────────────────────────────────
if [ "${1:-}" = "install" ]; then
  shift

  type=""
  agent=""
  extra_args=()
  while [[ $# -gt 0 ]]; do
    case $1 in
      --type)  type="$2";  shift 2 ;;
      --agent) agent="$2"; shift 2 ;;
      *)       extra_args+=("$1"); shift ;;
    esac
  done

  # Map --type values to installer --package values
  case "${type}" in
    core)         package="core" ;;
    full|all)     package="all" ;;
    loader)       package="loader" ;;
    onboarder)    package="onboarder" ;;
    "")           package="" ;;  # let installer prompt
    *)            echo "Unknown type: ${type}. Use: core, loader, full" >&2; exit 1 ;;
  esac

  # Find install.sh — check CWD first, then relative to this script
  installer=""
  for candidate in \
    "${PWD}/install.sh" \
    "${PWD}/installers/install.sh" \
    "$(cd "$(dirname "$0")/../.." 2>/dev/null && pwd)/installers/install.sh"; do
    if [ -f "$candidate" ]; then
      installer="$candidate"
      break
    fi
  done

  if [ -z "$installer" ]; then
    echo "Error: install.sh not found." >&2
    echo "Run this command from the customer-pack-distributable directory." >&2
    exit 1
  fi

  cmd=(bash "$installer")
  [ -n "$package" ] && cmd+=(--package "$package")
  [ -n "$agent" ]   && cmd+=(--agent "$agent")
  cmd+=("${extra_args[@]}")

  exec "${cmd[@]}"
fi

# ── Default: delegate to engine binary ───────────────────────────────
exec "$(dirname "$0")/tabnine-ctx-cli-engine" "$@"
