        full: external_exports.object({ cron: external_exports.string(), mode: external_exports.literal("full") }).optional()
      }).optional()
    });
  }
});

// loader/src/manifest/parser.ts
var parser_exports = {};
__export(parser_exports, {
  parseManifest: () => parseManifest
});
function parseManifest(filePath, env) {
  let raw;
  try {
    raw = (0, import_node_fs.readFileSync)(filePath, "utf-8");
  } catch (err) {
    throw new CategorizedError(`Cannot read manifest: ${filePath}`, {
      code: "LOADER_CFG_001",
      category: "configuration",
      remediation: `Check that the manifest file exists and is readable: ${filePath}`,
      retryable: false,
      cause: err instanceof Error ? err : void 0,
      details: { filePath }
    });
  }
  const fingerprint = computeStructuralFingerprint(raw);
  let interpolated;
  try {
    interpolated = interpolateEnv(raw, env);
  } catch (err) {
    if (err instanceof CategorizedError) {
      throw err;
    }
    throw new CategorizedError(`Failed to interpolate manifest: ${filePath}`, {
      code: "LOADER_CFG_002",
      category: "configuration",
      remediation: "Check that all referenced environment variables are set.",
      retryable: false,
      cause: err instanceof Error ? err : void 0
    });
  }
  let parsed;
  try {
    parsed = (0, import_yaml2.parse)(interpolated);
  } catch (err) {
    throw new CategorizedError(`Invalid YAML in manifest: ${filePath}`, {
      code: "LOADER_CFG_001",
      category: "configuration",
      remediation: `Fix YAML syntax in ${filePath}. ${err instanceof Error ? err.message : ""}`,
      retryable: false,
      cause: err instanceof Error ? err : void 0
    });
  }
  const result = loaderManifestSchema.safeParse(parsed);
  if (!result.success) {
    const issues = result.error.issues.map((i) => `  ${i.path.join(".")}: ${i.message}`).join("\n");
    throw new CategorizedError(`Manifest validation failed:
${issues}`, {
      code: "LOADER_CFG_001",
      category: "validation",
      remediation: `Fix validation errors in ${filePath}:
${issues}`,
      retryable: false,
      details: { filePath, issues: result.error.issues }
    });
  }
  validateCredentialRefs(result.data, filePath);
  validateUniqueSourceNames(result.data, filePath);
  return { manifest: result.data, fingerprint };
}
function computeStructuralFingerprint(raw) {
  const placeholdered = raw.replace(/\$\{[^}]+\}/g, "__ENV_VAR__");
  let parsed;
  try {
    parsed = (0, import_yaml2.parse)(placeholdered);
  } catch {
    return (0, import_node_crypto.createHash)("sha256").update(raw).digest("hex").slice(0, 16);
  }
  const canonical = JSON.stringify(deepSortKeys(parsed));
  return (0, import_node_crypto.createHash)("sha256").update(canonical).digest("hex").slice(0, 16);
}
function deepSortKeys(value) {
  if (value === null || value === void 0) {
    return value;
  }
  if (Array.isArray(value)) {
    return value.map(deepSortKeys);
  }
  if (typeof value === "object") {
    const sorted = {};
    for (const key of Object.keys(value).sort()) {
      sorted[key] = deepSortKeys(value[key]);
    }
    return sorted;
  }
  return value;
}
function validateCredentialRefs(manifest, filePath) {
  const credNames = new Set(Object.keys(manifest.credentials));
  for (const [wsName, ws] of Object.entries(manifest.workspaces)) {
    for (const source of ws.sources) {
      if (!credNames.has(source.credential)) {
        throw new CategorizedError(
          `Source '${source.name}' in workspace '${wsName}' references undefined credential '${source.credential}'`,
          {
            code: "LOADER_CFG_001",
            category: "validation",
            remediation: `Add credential '${source.credential}' to the credentials section in ${filePath}, or fix the reference.`,
            retryable: false,
            details: { workspace: wsName, source: source.name, credential: source.credential }
          }
        );
      }
    }
  }
}
function validateUniqueSourceNames(manifest, filePath) {
  for (const [wsName, ws] of Object.entries(manifest.workspaces)) {
    const seen = /* @__PURE__ */ new Set();
    for (const source of ws.sources) {
      if (seen.has(source.name)) {
        throw new CategorizedError(
          `Duplicate source name '${source.name}' in workspace '${wsName}'`,
          {
            code: "LOADER_CFG_001",
            category: "validation",
            remediation: `Each source in workspace '${wsName}' must have a unique name. Rename one of the duplicate '${source.name}' sources in ${filePath}.`,
            retryable: false,
            details: { workspace: wsName, source: source.name }
          }
        );
      }
      seen.add(source.name);
    }
  }
}
