// loader/src/state/checkpoint.ts
var checkpoint_exports = {};
__export(checkpoint_exports, {
  CheckpointStore: () => CheckpointStore
});
var import_node_fs2, import_node_path, import_node_crypto2, CheckpointStore;
var init_checkpoint = __esm({
  "loader/src/state/checkpoint.ts"() {
    "use strict";
    import_node_fs2 = require("node:fs");
    import_node_path = require("node:path");
    import_node_crypto2 = require("node:crypto");
    init_dist();
    CheckpointStore = class {
      stateDir;
      writeQueue = Promise.resolve();
      constructor(baseDir) {
        this.stateDir = (0, import_node_path.join)(baseDir, ".ctx-loader", "runs");
        (0, import_node_fs2.mkdirSync)(this.stateDir, { recursive: true });
      }
      /**
       * Write state atomically: unique temp file → rename.
       * Serialized via queue so concurrent calls don't race.
       */
      async checkpoint(run) {
        this.writeQueue = this.writeQueue.then(() => this.doCheckpoint(run));
        await this.writeQueue;
      }
      doCheckpoint(run) {
        run.stateVersion++;
        const targetPath = (0, import_node_path.join)(this.stateDir, `${run.id}.json`);
        const tempPath = `${targetPath}.tmp.${(0, import_node_crypto2.randomUUID)().slice(0, 8)}`;
        const backupPath = `${targetPath}.bak`;
        const content = JSON.stringify(run, null, 2);
        (0, import_node_fs2.writeFileSync)(tempPath, content, { mode: 384 });
        if ((0, import_node_fs2.existsSync)(targetPath)) {
          (0, import_node_fs2.copyFileSync)(targetPath, backupPath);
        }
        (0, import_node_fs2.renameSync)(tempPath, targetPath);
        (0, import_node_fs2.writeFileSync)((0, import_node_path.join)(this.stateDir, "latest-run"), run.id, { mode: 384 });
      }
      /**
       * Load a run by ID, with .bak fallback if primary is corrupted.
       */
      async load(runId) {
        const targetPath = (0, import_node_path.join)(this.stateDir, `${runId}.json`);
        try {
          return this.readStateFile(targetPath);
        } catch {
          const backupPath = `${targetPath}.bak`;
          try {
            return this.readStateFile(backupPath);
          } catch {
            throw catalogError("LOADER_STATE_002", `Cannot load checkpoint for run ${runId}`);
          }
        }
      }
      /**
       * Load the most recent run.
       */
      async loadLatest() {
        const pointerPath = (0, import_node_path.join)(this.stateDir, "latest-run");
        if (!(0, import_node_fs2.existsSync)(pointerPath)) {
          return null;
        }
        try {
          const runId = (0, import_node_fs2.readFileSync)(pointerPath, "utf-8").trim();
          return await this.load(runId);
        } catch {
          return null;
        }
      }
      /**
       * Validate manifest fingerprint matches before resume.
       */
      validateFingerprint(run, currentFingerprint) {
        if (run.manifestFingerprint !== currentFingerprint) {
          throw catalogError(
            "LOADER_CFG_003",
            "Manifest structure changed since last run \u2014 cannot resume safely"
          );
        }
      }
      get dir() {
        return this.stateDir;
      }
      readStateFile(path) {
        if (!(0, import_node_fs2.existsSync)(path)) {
          throw new CategorizedError(`State file not found: ${path}`, {
            code: "LOADER_STATE_002",
            category: "validation",
            remediation: "No checkpoint exists for this run.",
            retryable: false
          });
        }
        const content = (0, import_node_fs2.readFileSync)(path, "utf-8");
        return JSON.parse(content);
      }
    };
  }
});

