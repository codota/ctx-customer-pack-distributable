var import_node_crypto4, import_node_path3, Orchestrator;
var init_orchestrator = __esm({
  "loader/src/pipeline/orchestrator.ts"() {
    "use strict";
    import_node_crypto4 = require("node:crypto");
    import_node_path3 = require("node:path");
    init_types2();
    init_checkpoint();
    init_api_client();
    init_agent_runner();
    init_pause_controller();
    init_concurrency_pool();
    init_stage_machine();
    Orchestrator = class {
      constructor(options) {
        this.options = options;
        this.checkpointStore = new CheckpointStore(options.baseDir);
        this.pauseController = new PauseController((0, import_node_path3.join)(options.baseDir, ".ctx-loader"));
        this.client = new CtxApiClient({
          apiUrl: options.manifest.ctx.apiUrl,
          apiKey: options.manifest.ctx.apiKey,
          timeout: options.manifest.networking?.timeout,
          retryAttempts: options.manifest.networking?.retryAttempts,
          retryBackoffMs: options.manifest.networking?.retryBackoffMs
        });
      }
      options;
      checkpointStore;
      pauseController;
      client;
      run;
      warnings = [];
      get controller() {
        return this.pauseController;
      }
      /**
       * Resume a previously paused/failed run from checkpoint.
       * Skips sources that already completed; retries failed ones.
       */
      async resume(existingRun) {
        this.run = existingRun;
        this.run.status = "running";
        this.pauseController.reset();
        for (const ws of Object.values(this.run.workspaces)) {
          for (const source of Object.values(ws.sources)) {
            if (source.status === "failed" && source.retryCount < (this.options.manifest.defaults?.maxRetries ?? 3)) {
              source.status = "pending";
              source.retryCount++;
              source.error = void 0;
              source.errorCode = void 0;
            }
            if (source.status === "paused") {
              source.status = "pending";
            }
          }
        }
        await this.checkpointStore.checkpoint(this.run);
        return this.runPipeline();
      }
      /**
       * Execute the full load pipeline (fresh start).
       */
      async execute() {
        const { manifest, manifestFingerprint, manifestPath, mode } = this.options;
        this.run = createEmptyLoadRun((0, import_node_crypto4.randomUUID)(), manifestPath, manifestFingerprint, mode);
        for (const [wsName, ws] of Object.entries(manifest.workspaces)) {
          this.run.workspaces[wsName] = {
            sources: {}
          };
          for (const source of ws.sources) {
            this.run.workspaces[wsName].sources[source.name] = createEmptySourceState();
          }
        }
        await this.checkpointStore.checkpoint(this.run);
        return this.runPipeline();
      }
      /** Pre-resolved credential IDs — resolved once before parallel source processing */
      resolvedCredentials = /* @__PURE__ */ new Map();
      /** Pre-resolved workspace IDs — resolved once before parallel source processing */
      resolvedWorkspaces = /* @__PURE__ */ new Map();
      async runPipeline() {
        const { manifest } = this.options;
        const defaults = manifest.defaults ?? {};
        if (this.pauseController.shouldStop) {
          for (const ws of Object.values(this.run.workspaces)) {
            for (const source of Object.values(ws.sources)) {
              if (source.status === "pending") {
                source.status = this.pauseController.isCancelled ? "cancelled" : "paused";
              }
            }
          }
          this.run.status = this.pauseController.isCancelled ? "failed" : "paused";
          this.run.endedAt = (/* @__PURE__ */ new Date()).toISOString();
          await this.checkpointStore.checkpoint(this.run);
          return { run: this.run, warnings: this.warnings };
        }
        await this.resolveAgentKinds(manifest);
        await this.preResolveCredentials(manifest);
        await this.preResolveWorkspaces(manifest);
        const pool = new ConcurrencyPool(defaults.concurrency ?? 4);
        const tasks = [];
        for (const [wsName, ws] of Object.entries(manifest.workspaces)) {
          for (const source of ws.sources) {
            tasks.push(async () => {
              await this.processSource(wsName, source.name, source, manifest);
            });
          }
        }
        await pool.all(tasks);
        const allSourceStates = Object.values(this.run.workspaces).flatMap(
          (ws) => Object.values(ws.sources).map((s) => s.status)
        );
        const anyFailed = allSourceStates.some((s) => s === "failed");
        const anyCancelled = allSourceStates.some((s) => s === "cancelled");
        const anyPaused = allSourceStates.some((s) => s === "paused");
        const allDone = allSourceStates.every(
          (s) => isTerminal(s) || s === "failed"
        );
        if (allDone && !anyFailed && !anyCancelled && !anyPaused) {
          this.run.status = "completed";
        } else if (anyFailed || anyCancelled || this.pauseController.isCancelled) {
          this.run.status = "failed";
        } else if (anyPaused || this.pauseController.shouldStop) {
          this.run.status = "paused";
        } else {
          this.run.status = "failed";
        }
        this.run.endedAt = (/* @__PURE__ */ new Date()).toISOString();
        await this.checkpointStore.checkpoint(this.run);
        for (const ws of Object.values(this.run.workspaces)) {
          for (const source of Object.values(ws.sources)) {
            source.apiCalls.push(...this.client.callLog);
          }
        }
        return { run: this.run, warnings: this.warnings };
      }
      async processSource(wsName, sourceName, sourceSpec, manifest) {
        const state = this.run.workspaces[wsName].sources[sourceName];
        if (isTerminal(state.status)) {
          return;
        }
        const defaults = manifest.defaults ?? {};
        try {
          if (this.pauseController.shouldStop) {
            return this.handlePause(state);
          }
          state.status = transition(state.status, "resolving_credential");
          state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
          await this.checkpointStore.checkpoint(this.run);
          state.credential = this.getResolvedCredential(sourceSpec.credential);
          await this.checkpointStore.checkpoint(this.run);
          if (this.pauseController.shouldStop) {
            return this.handlePause(state);
          }
          state.status = transition(state.status, "resolving_datasource");
          state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
          state.dataSource = await this.resolveDataSource(
            sourceName,
            sourceSpec.type,
            state.credential.id,
            sourceSpec.config
          );
          await this.checkpointStore.checkpoint(this.run);
          if (this.pauseController.shouldStop) {
            return this.handlePause(state);
          }
          state.status = transition(state.status, "adding_to_workspace");
          state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
          const wsState = this.run.workspaces[wsName];
          if (!wsState.workspace) {
            wsState.workspace = this.resolvedWorkspaces.get(wsName);
            await this.checkpointStore.checkpoint(this.run);
          }
          if (state.dataSource && wsState.workspace) {
            try {
              await this.client.addDataSourceToWorkspace(wsState.workspace.id, state.dataSource.id);
            } catch {
              this.warnings.push(`Could not associate data source '${sourceName}' with workspace '${wsName}' \u2014 proceeding`);
            }
          }
          state.status = transition(state.status, "awaiting_sync");
          state.syncStartedAt = (/* @__PURE__ */ new Date()).toISOString();
          await this.checkpointStore.checkpoint(this.run);
          await this.awaitSync(state, defaults.syncTimeout ?? 3600);
          if (this.pauseController.shouldStop) {
            return this.handlePause(state);
          }
          if (sourceSpec.agents && sourceSpec.agents.length > 0) {
            state.status = transition(state.status, "running_agents");
            state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
            await this.checkpointStore.checkpoint(this.run);
            for (const agentName of sourceSpec.agents) {
              if (this.pauseController.shouldStop) {
                return this.handlePause(state);
              }
              const agentKindId = this.run.agentKindCache[agentName];
              if (!agentKindId) {
                this.warnings.push(`Agent '${agentName}' not found \u2014 skipping`);
                continue;
              }
              const result = await runAgentWithContinuation(this.client, {
                agentKindId,
                agentName,
                pollIntervalMs: (defaults.pollInterval ?? 30) * 1e3,
                maxContinuations: defaults.maxContinuations ?? 3,
                timeoutMs: (defaults.agentTimeout ?? 1800) * 1e3
              });
              state.agentRuns.push(result);
              state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
              await this.checkpointStore.checkpoint(this.run);
            }
          }
          state.status = transition(state.status, "completed");
          state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
          await this.checkpointStore.checkpoint(this.run);
        } catch (err) {
          state.status = "failed";
          state.error = err instanceof Error ? err.message : String(err);
          state.errorCode = err instanceof Error && "code" in err ? err.code : void 0;
          await this.checkpointStore.checkpoint(this.run);
        }
      }
      handlePause(state) {
        state.status = this.pauseController.isCancelled ? "cancelled" : "paused";
      }
      /**
       * Pre-resolve all unique credentials before parallel source processing.
       * This prevents the race where parallel sources sharing a credential
       * both do list-then-create and one gets a 409 duplicate.
       */
      async preResolveCredentials(manifest) {
        const credNames = /* @__PURE__ */ new Set();
        for (const ws of Object.values(manifest.workspaces)) {
          for (const source of ws.sources) {
            credNames.add(source.credential);
          }
        }
        for (const credName of credNames) {
          if (this.resolvedCredentials.has(credName)) {
            continue;
          }
          const spec = manifest.credentials[credName];
          if (!spec) {
            continue;
          }
          const existing = await this.client.listCredentials(spec.type);
          const found = existing.find((c) => c.name === credName);
          if (found) {
            this.resolvedCredentials.set(credName, { id: found.id, name: credName, createdByThisRun: false });
          } else {
            const { id } = await this.client.createCredential({
              name: credName,
              type: spec.type,
              data: spec.data
            });
            this.resolvedCredentials.set(credName, { id, name: credName, createdByThisRun: true });
          }
        }
      }
      /**
       * Get a pre-resolved credential. Must call preResolveCredentials first.
       */
      getResolvedCredential(name) {
        const resolved = this.resolvedCredentials.get(name);
        if (!resolved) {
          throw new Error(`Credential '${name}' was not pre-resolved`);
        }
        return resolved;
      }
      /**
       * Pre-resolve all unique workspaces before parallel source processing.
       */
      async preResolveWorkspaces(manifest) {
        for (const wsName of Object.keys(manifest.workspaces)) {
          if (this.resolvedWorkspaces.has(wsName)) {
            continue;
          }
          const ref = await this.resolveWorkspace(wsName);
          this.resolvedWorkspaces.set(wsName, ref);
        }
      }
      async resolveDataSource(name, type, credentialId, config) {
        const existing = await this.client.listDataSources();
        const found = existing.find((ds) => ds.name === name);
        if (found) {
          await this.client.syncDataSource(found.id);
          return { id: found.id, name, createdByThisRun: false };
        }
        const { id } = await this.client.createDataSource({ name, type, credentialId, config });
        return { id, name, createdByThisRun: true };
      }
      async resolveWorkspace(name) {
        const existing = await this.client.listWorkspaces();
        const found = existing.find((w) => w.name === name);
        if (found) {
          return { id: found.id, name, createdByThisRun: false };
        }
        const { id } = await this.client.createWorkspace({ name });
        return { id, name, createdByThisRun: true };
      }
      async awaitSync(state, timeoutSeconds) {
        if (!state.dataSource) {
          return;
        }
        const deadline = Date.now() + timeoutSeconds * 1e3;
        while (Date.now() < deadline) {
          const ds = await this.client.getDataSource(state.dataSource.id);
          state.lastProgressAt = (/* @__PURE__ */ new Date()).toISOString();
          if (ds.syncStatus === "completed" || ds.syncStatus === "synced" || ds.status === "active") {
            state.syncCompletedAt = (/* @__PURE__ */ new Date()).toISOString();
            return;
          }
          if (ds.syncStatus === "failed" || ds.syncStatus === "error") {
            this.warnings.push(`Sync for '${state.dataSource.name}' reported failure \u2014 proceeding with available data`);
            state.syncCompletedAt = (/* @__PURE__ */ new Date()).toISOString();
            return;
          }
          if (this.pauseController.shouldStop) {
            return;
          }
          await new Promise((resolve2) => setTimeout(resolve2, 3e4));
        }
        this.warnings.push(
          `Sync for '${state.dataSource.name}' timed out after ${timeoutSeconds}s \u2014 proceeding with available data`
        );
        state.syncCompletedAt = (/* @__PURE__ */ new Date()).toISOString();
      }
      async resolveAgentKinds(manifest) {
        const agentNames = /* @__PURE__ */ new Set();
        for (const ws of Object.values(manifest.workspaces)) {
          for (const source of ws.sources) {
            for (const agent of source.agents ?? []) {
              agentNames.add(agent);
            }
          }
        }
        if (agentNames.size === 0) {
          return;
        }
        const kinds = await this.client.listAgentKinds();
        for (const name of agentNames) {
          const kind = kinds.find((k) => k.name === name);
          if (kind) {
            this.run.agentKindCache[name] = kind.id;
          } else {
            this.warnings.push(`Agent kind '${name}' not found on server`);
          }
        }
      }
    };
  }
});

// loader/src/pipeline/rollback.ts
var rollback_exports = {};
__export(rollback_exports, {
  rollbackRun: () => rollbackRun
});
async function rollbackRun(run, client, checkpoint) {
  const result = {
    credentialsDeleted: 0,
    dataSourcesDeleted: 0,
    agentRunsCancelled: 0,
    warnings: [],
    skippedPreExisting: 0
  };
  const rolledBackSources = /* @__PURE__ */ new Set();
  const workspaceEntries = Object.entries(run.workspaces);
  for (const [_wsName, ws] of workspaceEntries.reverse()) {
    const sourceEntries = Object.entries(ws.sources);
    for (const [sourceName, source] of sourceEntries.reverse()) {
      for (const agentRun of [...source.agentRuns, ...source.analysisRuns]) {
        for (const entry of agentRun.runs) {
          if (entry.status === "running" || entry.status === "pending") {
            try {
              result.agentRunsCancelled++;
            } catch {
              result.warnings.push(`Failed to cancel agent run ${entry.runId}`);
            }
          }
        }
      }
      let sourceRollbackOk = true;
      if (source.dataSource) {
        if (source.dataSource.createdByThisRun) {
          try {
            await client.deleteDataSource(source.dataSource.id);
            result.dataSourcesDeleted++;
          } catch (err) {
            sourceRollbackOk = false;
            result.warnings.push(
              `Failed to delete data source '${sourceName}': ${err instanceof Error ? err.message : String(err)}`
            );
          }
        } else {
          result.skippedPreExisting++;
        }
      }
      if (sourceRollbackOk) {
        source.status = "rolled_back";
        rolledBackSources.add(sourceName);
      }
    }
  }
  const deletedCredIds = /* @__PURE__ */ new Set();
  for (const [_wsName, ws] of workspaceEntries) {
    for (const [sourceName, source] of Object.entries(ws.sources)) {
      if (!rolledBackSources.has(sourceName)) {
        continue;
      }
      if (!source.credential || !source.credential.createdByThisRun) {
        if (source.credential && !source.credential.createdByThisRun) {
          result.skippedPreExisting++;
        }
        continue;
      }
      if (deletedCredIds.has(source.credential.id)) {
        continue;
      }
      try {
        await client.deleteCredential(source.credential.id);
        deletedCredIds.add(source.credential.id);
        result.credentialsDeleted++;
      } catch (err) {
        result.warnings.push(
          `Failed to delete credential '${source.credential.name}': ${err instanceof Error ? err.message : String(err)}`
        );
      }
    }
  }
  const allRolledBack = Object.values(run.workspaces).every(
    (ws) => Object.values(ws.sources).every((s) => s.status === "rolled_back")
  );
  run.status = allRolledBack ? "rolled_back" : "failed";
  run.endedAt = (/* @__PURE__ */ new Date()).toISOString();
  await checkpoint.checkpoint(run);
  return result;
}
var init_rollback = __esm({
  "loader/src/pipeline/rollback.ts"() {
    "use strict";
  }
});

// loader/src/progress/staleness.ts
var staleness_exports = {};
__export(staleness_exports, {
  calculateStalenessTier: () => calculateStalenessTier,
  getPhase: () => getPhase,
  getStalenessInfo: () => getStalenessInfo
});
function getPhase(status) {
  if (status === "awaiting_sync") {
    return "sync";
  }
  if (status === "running_agents" || status === "running_analysis") {
    return "agent";
  }
  return "other";
}
function calculateStalenessTier(ageSeconds, phase) {
  const t = THRESHOLDS[phase];
  if (ageSeconds < t.fresh) {
    return "fresh";
  }
  if (ageSeconds < t.warm) {
    return "warm";
  }
  if (ageSeconds < t.stale) {
    return "stale";
  }
  return "critical";
}
function getStalenessInfo(sourceName, status, lastProgressAt) {
  const phase = getPhase(status);
  if (!lastProgressAt) {
    return { sourceName, tier: "critical", ageSeconds: Infinity, phase };
  }
  const ageSeconds = Math.floor((Date.now() - new Date(lastProgressAt).getTime()) / 1e3);
  const tier = calculateStalenessTier(ageSeconds, phase);
  return { sourceName, tier, ageSeconds, phase };
}
var THRESHOLDS;
var init_staleness = __esm({
  "loader/src/progress/staleness.ts"() {
    "use strict";
    THRESHOLDS = {
      sync: { fresh: 120, warm: 600, stale: 1800, critical: Infinity },
      agent: { fresh: 60, warm: 300, stale: 900, critical: Infinity },
      other: { fresh: 60, warm: 300, stale: 600, critical: Infinity }
    };
  }
});

