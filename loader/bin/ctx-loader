          cause: this.cause instanceof Error ? this.cause.message : void 0
        };
      }
    };
  }
});

// shared/dist/errors/error-catalog.js
function catalogError(code, message, options) {
  const def = ERROR_CATALOG[code];
  if (!def) {
    return new CategorizedError(message, {
      code,
      category: "unknown",
      remediation: "An unexpected error occurred. Check the logs for details.",
      retryable: false,
      details: options?.details,
      cause: options?.cause
    });
  }
  return new CategorizedError(message, {
    code,
    category: def.category,
    remediation: options?.remediationOverride ?? def.remediation,
    retryable: def.retryable,
    details: options?.details,
    cause: options?.cause
  });
}
function classifyHttpStatus(status) {
  if (status === 401 || status === 403) {
    return { category: "authentication", retryable: false };
  }
  if (status === 404 || status === 410) {
    return { category: "validation", retryable: false };
  }
  if (status === 409) {
    return { category: "validation", retryable: false };
  }
  if (status === 429) {
    return { category: "rate_limit", retryable: true };
  }
  if (status === 400 || status === 422) {
    return { category: "validation", retryable: false };
  }
  if (status >= 500) {
    return { category: "server_error", retryable: true };
  }
  return { category: "unknown", retryable: false };
}
function classifyNetworkError(err) {
  const msg = err.message.toLowerCase();
  const code = err.code?.toLowerCase() ?? "";
  if (code === "econnrefused" || msg.includes("econnrefused")) {
    return { category: "network", retryable: true };
  }
  if (code === "etimedout" || code === "esockettimedout" || msg.includes("timeout") || msg.includes("etimedout")) {
    return { category: "timeout", retryable: true };
  }
  if (msg.includes("certificate") || msg.includes("ssl") || msg.includes("tls") || code === "cert_has_expired" || code === "unable_to_verify_leaf_signature") {
    return { category: "network", retryable: false };
  }
  if (code === "econnreset" || code === "epipe" || code === "enotfound" || msg.includes("econnreset") || msg.includes("socket hang up")) {
    return { category: "network", retryable: true };
  }
  return { category: "network", retryable: true };
}
