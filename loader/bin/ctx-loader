var init_api_client = __esm({
  "loader/src/engine/api-client.ts"() {
    "use strict";
    import_node_crypto3 = require("node:crypto");
    init_dist();
    CtxApiClient = class {
      baseUrl;
      apiKey;
      timeout;
      retryAttempts;
      retryBackoffMs;
      /** Accumulated API call records for traceability */
      callLog = [];
      constructor(options) {
        this.baseUrl = options.apiUrl.replace(/\/$/, "");
        this.apiKey = options.apiKey;
        this.timeout = options.timeout ?? 3e4;
        this.retryAttempts = options.retryAttempts ?? 3;
        this.retryBackoffMs = options.retryBackoffMs ?? 1e3;
      }
      // ─── Credentials ────────────────────────────────────────
      async listCredentials(type) {
        const query = type ? `?type=${encodeURIComponent(type)}` : "";
        const resp = await this.get(
          `/api/credentials${query}`
        );
        return resp.data;
      }
      async createCredential(body) {
        const resp = await this.post("/api/credentials", body);
        return resp.data;
      }
      // ─── Data Sources ───────────────────────────────────────
      async listDataSources() {
        const resp = await this.get(
          "/api/data-sources"
        );
        return resp.data;
      }
      async createDataSource(body) {
        const resp = await this.post("/api/data-sources", body);
        return resp.data;
      }
