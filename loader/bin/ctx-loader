        const resp = await this.get(
          `/api/data-sources/${id}/events?limit=${limit}`
        );
        return resp.data;
      }
      async deleteDataSource(id) {
        await this.delete(`/api/data-sources/${id}`);
      }
      async deleteCredential(id) {
        await this.delete(`/api/credentials/${id}`);
      }
      // ─── Agent Runs ─────────────────────────────────────────
      async createAgentRun(body) {
        const resp = await this.post("/api/agent-runs", body);
        return resp.data;
      }
      async getAgentRun(id) {
        const resp = await this.get(
          `/api/agent-runs/${id}`
        );
        return resp.data;
      }
      async continueAgentRun(id) {
        const resp = await this.post(`/api/agent-runs/${id}/continue`, {});
        return resp.data;
      }
      // ─── Agent Kinds ────────────────────────────────────────
      async listAgentKinds() {
        const resp = await this.get("/api/agent-kinds");
        return resp.data;
      }
      // ─── Workspaces ─────────────────────────────────────────
      async listWorkspaces() {
        const resp = await this.get("/api/workspaces");
        return resp.data;
      }
      async createWorkspace(body) {
        const resp = await this.post("/api/workspaces", body);
        return resp.data;
      }
      async addDataSourceToWorkspace(workspaceId, dataSourceId) {
        await this.post(`/api/workspaces/${workspaceId}/data-sources`, { dataSourceId });
      }
      // ─── Health ─────────────────────────────────────────────
      async health() {
        const resp = await this.get("/api/health");
        return resp.data;
      }
      // ─── Core HTTP ──────────────────────────────────────────
      async get(path) {
        return this.request("GET", path);
      }
      async post(path, body) {
        return this.request("POST", path, body);
      }
      async delete(path) {
        return this.request("DELETE", path);
      }
      async request(method, path, body) {
        const requestId = (0, import_node_crypto3.randomUUID)();
        const url = `${this.baseUrl}${path}`;
        const record = {
          requestId,
          endpoint: `${method} ${path}`,
          timestamp: (/* @__PURE__ */ new Date()).toISOString()
        };
        let lastError;
        for (let attempt = 0; attempt <= this.retryAttempts; attempt++) {
          try {
            const controller = new AbortController();
            const timeoutId = setTimeout(() => controller.abort(), this.timeout);
            const response = await fetch(url, {
              method,
              headers: {
                "Content-Type": "application/json",
                Authorization: `Bearer ${this.apiKey}`,
                "X-Request-ID": requestId
              },
              body: body ? JSON.stringify(body) : void 0,
              signal: controller.signal
            });
            clearTimeout(timeoutId);
            record.statusCode = response.status;
            if (!response.ok) {
              const { category, retryable } = classifyHttpStatus(response.status);
              if (retryable && attempt < this.retryAttempts) {
                const retryAfter = response.headers.get("retry-after");
                const delay = retryAfter ? parseInt(retryAfter, 10) * 1e3 : this.retryBackoffMs * Math.pow(2, attempt);
                await new Promise((r) => setTimeout(r, delay));
                continue;
              }
              const errorBody = await response.text().catch(() => "");
              record.errorCode = `HTTP_${response.status}`;
              this.callLog.push(record);
              throw catalogError(
                category === "authentication" ? "LOADER_AUTH_001" : category === "rate_limit" ? "LOADER_RATE_001" : category === "server_error" ? "LOADER_SRV_001" : "LOADER_NET_001",
                `${method} ${path} returned ${response.status}: ${errorBody}`.slice(0, 500),
                { details: { url, method, statusCode: response.status, requestId } }
              );
            }
            let data;
            const contentLength = response.headers.get("content-length");
            if (response.status === 204 || contentLength === "0") {
              data = void 0;
            } else {
              const text = await response.text();
              data = text ? JSON.parse(text) : void 0;
            }
            this.callLog.push(record);
            return { data, requestId, statusCode: response.status };
          } catch (err) {
            if (err instanceof CategorizedError) {
              throw err;
            }
            lastError = err instanceof Error ? err : new Error(String(err));
            const { retryable } = classifyNetworkError(lastError);
            if (retryable && attempt < this.retryAttempts) {
              const delay = this.retryBackoffMs * Math.pow(2, attempt);
              await new Promise((r) => setTimeout(r, delay));
              continue;
            }
            record.errorCode = lastError.code ?? "NETWORK_ERROR";
            this.callLog.push(record);
            throw catalogError("LOADER_NET_001", `${method} ${path}: ${lastError.message}`, {
              cause: lastError,
              details: { url, method, requestId }
            });
          }
        }
        this.callLog.push(record);
        throw catalogError("LOADER_NET_001", `${method} ${path}: max retries exceeded`, {
          cause: lastError
        });
      }
    };
  }
});

// loader/src/engine/agent-runner.ts
async function runAgentWithContinuation(client, options) {
  const record = {
    agentName: options.agentName,
    agentKindId: options.agentKindId,
    runs: [],
    overallStatus: "running",
    error: void 0
  };
  const { id: runId } = await client.createAgentRun({
    agentKindId: options.agentKindId,
    input: options.input
  });
  let currentRunId = runId;
  let continuations = 0;
  while (true) {
    const entry = {
      runId: currentRunId,
      status: "running",
      startedAt: (/* @__PURE__ */ new Date()).toISOString(),
      isContinuation: continuations > 0,
      continuedFromRunId: continuations > 0 ? record.runs[record.runs.length - 1]?.runId : void 0
    };
    record.runs.push(entry);
    const result = await pollRunCompletion(client, currentRunId, options.pollIntervalMs, options.timeoutMs);
    entry.status = result.status;
    entry.completedAt = (/* @__PURE__ */ new Date()).toISOString();
    if (result.status === "completed") {
      record.overallStatus = "completed";
      break;
    }
    if (result.status === "cancelled") {
      record.overallStatus = "failed";
      record.error = "Agent run was cancelled";
      break;
    }
    if (result.status === "failed") {
      record.overallStatus = "failed";
      record.error = result.error ?? "Agent run failed";
      break;
    }
    if ((result.status === "timeout" || result.status === "budget_exceeded") && continuations < options.maxContinuations) {
      const { id: nextRunId } = await client.continueAgentRun(currentRunId);
      currentRunId = nextRunId;
      continuations++;
      continue;
    }
    record.overallStatus = "failed";
    record.error = `Agent run ended with status '${result.status}' after ${continuations} continuation(s)`;
    break;
  }
  return record;
}
async function pollRunCompletion(client, runId, pollIntervalMs, timeoutMs) {
  const deadline = Date.now() + timeoutMs;
  while (Date.now() < deadline) {
    const run = await client.getAgentRun(runId);
    if (["completed", "failed", "cancelled", "timeout", "budget_exceeded"].includes(run.status)) {
      return { status: run.status, error: run.error };
    }
    await new Promise((resolve2) => setTimeout(resolve2, pollIntervalMs));
  }
  return { status: "timeout", error: "Client-side poll timeout exceeded" };
}
