// shared/dist/config/env-interpolation.js
function interpolateEnv(content, env = process.env) {
  return content.replace(/\$\{([^}]+)\}/g, (_match, expr) => {
    const defaultSep = expr.indexOf(":-");
    if (defaultSep !== -1) {
      const varName2 = expr.slice(0, defaultSep);
      const defaultValue = expr.slice(defaultSep + 2);
      const value2 = env[varName2];
      return value2 !== void 0 && value2 !== "" ? value2 : defaultValue;
    }
    const varName = expr.trim();
    const value = env[varName];
    if (value === void 0 || value === "") {
      throw new CategorizedError(`Environment variable ${varName} is not set`, {
        code: "LOADER_CFG_002",
        category: "configuration",
        remediation: `Set the environment variable ${varName} before running this command.`,
        retryable: false,
        details: { varName }
      });
    }
    return value;
  });
}
