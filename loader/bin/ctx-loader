      console.error(`Resume failed: ${err instanceof Error ? err.message : String(err)}`);
    }
    process.exit(1);
  }
});
program2.command("pause").description("Cooperative pause (takes effect at next stage boundary)").option("--json", "Output as JSON").action(async (opts) => {
  const { writeFileSync: writeFileSync2, mkdirSync: mkdirSync3 } = await import("node:fs");
  const { join: join4 } = await import("node:path");
  const signalDir = join4(process.cwd(), ".ctx-loader");
  mkdirSync3(signalDir, { recursive: true });
  writeFileSync2(join4(signalDir, "pause-signal"), "", { mode: 384 });
  if (opts.json) {
    console.log(JSON.stringify({ status: "pause_signalled" }));
  } else {
    console.log("Pause signalled. The load will pause at the next stage boundary.");
  }
});
program2.command("cancel").description("Cooperative cancel (takes effect at next stage boundary)").option("--json", "Output as JSON").action(async (opts) => {
  const { writeFileSync: writeFileSync2, mkdirSync: mkdirSync3 } = await import("node:fs");
  const { join: join4 } = await import("node:path");
  const signalDir = join4(process.cwd(), ".ctx-loader");
  mkdirSync3(signalDir, { recursive: true });
  writeFileSync2(join4(signalDir, "cancel-signal"), "", { mode: 384 });
  if (opts.json) {
    console.log(JSON.stringify({ status: "cancel_signalled" }));
  } else {
    console.log("Cancel signalled. The load will stop at the next stage boundary.");
  }
});
program2.command("rollback").description("Rollback resources created by the last run (provenance-safe)").option("--json", "Output as JSON").option("--manifest <path>", "Manifest file path", "ctx-loader.yaml").action(async (opts) => {
  try {
    const { CheckpointStore: CheckpointStore2 } = await Promise.resolve().then(() => (init_checkpoint(), checkpoint_exports));
    const { parseManifest: parseManifest2 } = await Promise.resolve().then(() => (init_parser(), parser_exports));
    const { rollbackRun: rollbackRun2 } = await Promise.resolve().then(() => (init_rollback(), rollback_exports));
    const { CtxApiClient: CtxApiClient2 } = await Promise.resolve().then(() => (init_api_client(), api_client_exports));
    const store = new CheckpointStore2(process.cwd());
    const run = await store.loadLatest();
    if (!run) {
      const msg = "No previous run found to rollback.";
      if (opts.json) {
        console.error(JSON.stringify({ error: msg }));
      } else {
        console.error(msg);
      }
      process.exit(1);
      return;
    }
    const { manifest } = parseManifest2((0, import_node_path4.resolve)(opts.manifest));
    const client = new CtxApiClient2({
      apiUrl: manifest.ctx.apiUrl,
      apiKey: manifest.ctx.apiKey
    });
    const result = await rollbackRun2(run, client, store);
    if (opts.json) {
      console.log(JSON.stringify(result, null, 2));
    } else {
      console.log(`Rollback complete:`);
      console.log(`  Credentials deleted: ${result.credentialsDeleted}`);
      console.log(`  Data sources deleted: ${result.dataSourcesDeleted}`);
      console.log(`  Pre-existing skipped: ${result.skippedPreExisting}`);
      if (result.warnings.length > 0) {
        console.log(`  Warnings:`);
        for (const w of result.warnings) {
          console.log(`    - ${w}`);
        }
      }
    }
  } catch (err) {
    if (opts.json) {
      console.error(JSON.stringify({ error: err instanceof Error ? err.message : String(err) }));
    } else {
      console.error(`Rollback failed: ${err instanceof Error ? err.message : String(err)}`);
    }
    process.exit(1);
  }
});
program2.command("report").description("Generate staleness report for all sources").option("--json", "Output as JSON").action(async (opts) => {
  const { CheckpointStore: CheckpointStore2 } = await Promise.resolve().then(() => (init_checkpoint(), checkpoint_exports));
  const { getStalenessInfo: getStalenessInfo2 } = await Promise.resolve().then(() => (init_staleness(), staleness_exports));
  const store = new CheckpointStore2(process.cwd());
  const run = await store.loadLatest();
  if (!run) {
    if (opts.json) {
      console.log(JSON.stringify({ sources: [] }));
    } else {
      console.log("No load runs found.");
    }
    return;
  }
  const report = [];
  for (const [wsName, ws] of Object.entries(run.workspaces)) {
    for (const [srcName, src] of Object.entries(ws.sources)) {
      const info = getStalenessInfo2(srcName, src.status, src.lastProgressAt);
      report.push({
        workspace: wsName,
        source: srcName,
        status: src.status,
        staleness: info.tier,
        ageSeconds: info.ageSeconds === Infinity ? null : info.ageSeconds
      });
    }
  }
  if (opts.json) {
    console.log(JSON.stringify({ runId: run.id, runStatus: run.status, sources: report }, null, 2));
  } else {
    console.log(`Run: ${run.id} (${run.status})`);
    for (const entry of report) {
      console.log(`  ${entry.workspace}/${entry.source}: ${entry.status} [${entry.staleness}]`);
    }
  }
});
program2.command("schedule").description("Set up recurring loads (node-cron daemon or system cron)").option("--manifest <path>", "Manifest file path", "ctx-loader.yaml").option("--daemon", "Run as node-cron daemon (cross-platform)").option("--remove", "Remove installed schedule").option("--json", "Output as JSON").action(async (opts) => {
  if (opts.json) {
    console.log(JSON.stringify({ status: "not_yet_implemented", daemon: !!opts.daemon }));
  } else {
    console.log("Scheduling not yet fully implemented.");
    console.log(`Use --daemon for cross-platform node-cron scheduling.`);
  }
});
program2.command("collect-logs").description("Package debug bundle for support (client-side traces only)").option("--output <path>", "Output file path", "ctx-loader-debug.tar.gz").option("--json", "Output as JSON").action(async (opts) => {
  if (opts.json) {
    console.log(JSON.stringify({ output: opts.output, status: "not_yet_implemented" }));
  } else {
    console.log(`Debug bundle collection not yet implemented. Output would go to: ${opts.output}`);
  }
});
program2.parse();
