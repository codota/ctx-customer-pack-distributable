// loader/src/pipeline/pause-controller.ts
var import_node_fs3, import_node_path2, PauseController;
var init_pause_controller = __esm({
  "loader/src/pipeline/pause-controller.ts"() {
    "use strict";
    import_node_fs3 = require("node:fs");
    import_node_path2 = require("node:path");
    PauseController = class {
      _state = "running";
      signalDir;
      /**
       * @param signalDir — directory to check for pause-signal / cancel-signal files.
       *   If not provided, only programmatic pause/cancel is supported.
       */
      constructor(signalDir) {
        this.signalDir = signalDir;
        if (signalDir) {
          (0, import_node_fs3.mkdirSync)(signalDir, { recursive: true });
        }
      }
      /** Signal a cooperative pause (programmatic). */
      requestPause() {
        if (this._state === "running") {
          this._state = "pause_requested";
        }
      }
      /** Signal a cooperative cancel (programmatic). */
      requestCancel() {
        this._state = "cancel_requested";
      }
      /**
       * Should the pipeline stop at the next clean boundary?
       * Also checks for signal files from external CLI commands.
       */
      get shouldStop() {
        this.checkSignalFiles();
        return this._state !== "running";
      }
      /** Is this a cancel (vs pause)? */
      get isCancelled() {
        this.checkSignalFiles();
        return this._state === "cancel_requested";
      }
      /** Current state. */
      get state() {
        this.checkSignalFiles();
        return this._state;
      }
      /** Reset for resume — clears state and removes signal files. */
      reset() {
        this._state = "running";
        this.clearSignalFiles();
      }
      /**
       * Check for signal files written by CLI pause/cancel commands.
       */
      checkSignalFiles() {
        if (!this.signalDir) {
          return;
        }
        const cancelPath = (0, import_node_path2.join)(this.signalDir, "cancel-signal");
        if ((0, import_node_fs3.existsSync)(cancelPath)) {
          this._state = "cancel_requested";
          return;
        }
        const pausePath = (0, import_node_path2.join)(this.signalDir, "pause-signal");
        if ((0, import_node_fs3.existsSync)(pausePath)) {
          if (this._state === "running") {
            this._state = "pause_requested";
          }
        }
      }
      /**
       * Remove signal files after they've been consumed.
       */
      clearSignalFiles() {
        if (!this.signalDir) {
          return;
        }
        for (const name of ["pause-signal", "cancel-signal"]) {
          const path = (0, import_node_path2.join)(this.signalDir, name);
          if ((0, import_node_fs3.existsSync)(path)) {
            try {
              (0, import_node_fs3.unlinkSync)(path);
            } catch {
            }
          }
        }
      }
    };
  }
});

// loader/src/pipeline/concurrency-pool.ts
var ConcurrencyPool;
var init_concurrency_pool = __esm({
  "loader/src/pipeline/concurrency-pool.ts"() {
    "use strict";
    ConcurrencyPool = class {
      constructor(concurrency) {
        this.concurrency = concurrency;
      }
      concurrency;
      running = 0;
      queue = [];
      /**
       * Execute a task within the pool. Waits if pool is full.
       */
      async run(task) {
        await this.acquire();
        try {
          return await task();
        } finally {
          this.release();
        }
      }
      /**
       * Execute multiple tasks with pool-limited concurrency.
       * Returns results in input order.
       */
      async all(tasks) {
        return Promise.all(tasks.map((task) => this.run(task)));
      }
      get activeCount() {
        return this.running;
      }
      get queuedCount() {
        return this.queue.length;
      }
      acquire() {
        if (this.running < this.concurrency) {
          this.running++;
          return Promise.resolve();
        }
        return new Promise((resolve2) => {
          this.queue.push(resolve2);
        });
      }
      release() {
        this.running--;
        const next = this.queue.shift();
        if (next) {
          this.running++;
          next();
        }
      }
    };
  }
});

// loader/src/pipeline/stage-machine.ts
function transition(current, next) {
  const valid = TRANSITIONS[current];
  if (!valid || !valid.includes(next)) {
    throw catalogError(
      "LOADER_STATE_001",
      `Invalid state transition: ${current} \u2192 ${next}`
    );
  }
  return next;
}
function isTerminal(status) {
  return ["completed", "skipped", "cancelled", "rolled_back"].includes(status);
}
var TRANSITIONS;
var init_stage_machine = __esm({
  "loader/src/pipeline/stage-machine.ts"() {
    "use strict";
    init_dist();
    TRANSITIONS = {
      pending: ["resolving_credential", "skipped", "paused", "cancelled"],
      resolving_credential: ["resolving_datasource", "failed", "paused", "cancelled"],
      resolving_datasource: ["adding_to_workspace", "failed", "paused", "cancelled"],
      adding_to_workspace: ["awaiting_sync", "failed", "paused", "cancelled"],
      awaiting_sync: ["running_agents", "failed", "paused", "cancelled"],
      running_agents: ["running_analysis", "completed", "failed", "paused", "cancelled"],
      running_analysis: ["validating", "completed", "failed", "paused", "cancelled"],
      validating: ["completed", "failed", "paused", "cancelled"],
      completed: [],
      failed: ["resolving_credential", "resolving_datasource", "awaiting_sync", "running_agents"],
      // retry
      skipped: [],
      cancelled: [],
      paused: [
        "resolving_credential",
        "resolving_datasource",
        "adding_to_workspace",
        "awaiting_sync",
        "running_agents",
        "running_analysis",
        "validating"
      ],
      rolled_back: []
    };
  }
});

