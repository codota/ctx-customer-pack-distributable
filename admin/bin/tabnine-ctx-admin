// shared/dist/logging/crash-handler.js
function installCrashHandlers(cliName) {
  const logDir = logsDir(process.cwd());
  function writeCrashLog(type, err) {
    try {
      (0, import_node_fs2.mkdirSync)(logDir, { recursive: true });
      const ts = (/* @__PURE__ */ new Date()).toISOString().replace(/[:.]/g, "-").slice(0, 19);
      const stack = err instanceof Error ? err.stack ?? err.message : String(err);
      const content = `timestamp: ${(/* @__PURE__ */ new Date()).toISOString()}
type: ${type}
cli: ${cliName}
--- stack trace ---
${stack}
`;
      (0, import_node_fs2.writeFileSync)((0, import_node_path2.join)(logDir, `${cliName}-crash-${ts}.log`), content, "utf-8");
    } catch {
    }
  }
  function formatErrorMessage(err) {
    if (err instanceof Error) {
      const cat = err;
      if (cat.code && cat.remediation) {
        return `${cat.message} [${cat.code}]. ${cat.remediation}`;
      }
      return err.message;
    }
    return String(err);
  }
  process.on("uncaughtException", (err) => {
    writeCrashLog("uncaughtException", err);
    const msg = formatErrorMessage(err);
    console.error(JSON.stringify({ error: msg, type: "crash", details: "Stack trace written to .tabnine/ctx/logs/" }));
    process.exit(1);
  });
  process.on("unhandledRejection", (reason) => {
    writeCrashLog("unhandledRejection", reason);
    const msg = formatErrorMessage(reason);
    console.error(JSON.stringify({ error: msg, type: "crash", details: "Stack trace written to .tabnine/ctx/logs/" }));
    process.exit(1);
  });
}
