// shared/dist/logging/logger.js
function createLogger(options) {
  const redactPaths = [...DEFAULT_REDACT_PATHS, ...options.redactPaths ?? []];
  const redact = { paths: redactPaths, censor: "[REDACTED]" };
  if (true) {
    const dest = options.filePath ? import_pino.default.destination({ dest: options.filePath, mkdir: true }) : import_pino.default.destination(1);
    return (0, import_pino.default)({ name: options.name, level: options.level ?? "info", redact }, dest);
  }
  const targets = [];
  if (options.pretty !== false) {
    targets.push({
      target: "pino-pretty",
      options: { colorize: true },
      level: options.level ?? "info"
    });
  } else {
    targets.push({
      target: "pino/file",
      options: { destination: 1 },
      // stdout
      level: options.level ?? "info"
    });
  }
  if (options.filePath) {
    targets.push({
      target: "pino/file",
      options: { destination: options.filePath, mkdir: true },
      level: "debug"
      // file always gets debug level
    });
  }
  return (0, import_pino.default)({
    name: options.name,
    level: "debug",
    // let transports filter
    redact,
    transport: {
      targets
    }
  });
}
