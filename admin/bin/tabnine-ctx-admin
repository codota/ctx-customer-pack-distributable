for (const [name, desc, importPath] of [
  ["deploy-azure", "Deploy CTX to Azure AKS (placeholder)", "./commands/deploy-azure.js"],
  ["deploy-aws", "Deploy CTX to AWS EKS (placeholder)", "./commands/deploy-aws.js"],
  ["deploy-gcp", "Deploy CTX to GCP GKE (placeholder)", "./commands/deploy-gcp.js"],
  ["upgrade", "Upgrade CTX deployment (placeholder)", "./commands/upgrade.js"],
  ["backup", "Backup CTX data (placeholder)", "./commands/backup.js"],
  ["restore", "Restore CTX data (placeholder)", "./commands/restore.js"]
]) {
  program2.command(name).description(desc).option("--json", "Output as JSON").action(async (opts) => {
    const mod = await import(importPath);
    const fn = Object.values(mod).find((v) => typeof v === "function");
    if (!fn) {
      console.error("Command not found");
      process.exit(1);
    }
    const result = await fn({ json: opts.json });
    if (opts.json) {
      console.log(JSON.stringify(result, null, 2));
    } else {
      console.log(result.message);
    }
  });
}
installCrashHandlers("tabnine-ctx-admin");
program2.parse();
