// shared/dist/process-lock.js
function formatLockContent(pid, cliName) {
  return `pid: ${pid}
cli: ${cliName}
acquiredAt: ${(/* @__PURE__ */ new Date()).toISOString()}
hostname: ${(0, import_node_os.hostname)()}
`;
}
function parseLockContent(raw) {
  const lines = raw.trim().split("\n");
  const map = /* @__PURE__ */ new Map();
  for (const line of lines) {
    const idx = line.indexOf(": ");
    if (idx > 0) {
      map.set(line.slice(0, idx), line.slice(idx + 2));
    }
  }
  const pidStr = map.get("pid");
  if (!pidStr) {
    return null;
  }
  const pid = parseInt(pidStr, 10);
  if (Number.isNaN(pid)) {
    return null;
  }
  return {
    pid,
    cliName: map.get("cli") ?? "unknown",
    acquiredAt: map.get("acquiredAt") ?? "unknown",
    hostname: map.get("hostname") ?? "unknown"
  };
}
function isPidAlive(pid) {
  try {
    process.kill(pid, 0);
    return true;
  } catch (err) {
    const code = err.code;
    if (code === "EPERM") {
      return true;
    }
    return false;
  }
}
function safeUnlink(path) {
  try {
    (0, import_node_fs3.unlinkSync)(path);
  } catch {
  }
}
function sleepSync(ms) {
  Atomics.wait(new Int32Array(new SharedArrayBuffer(4)), 0, 0, ms);
}
var import_node_fs3, import_node_path3, import_node_os, log, ProcessLock;
var init_process_lock = __esm({
  "shared/dist/process-lock.js"() {
    "use strict";
    import_node_fs3 = require("node:fs");
    import_node_path3 = require("node:path");
    import_node_os = require("node:os");
    init_error_catalog();
    init_logger();
    log = createLogger({ name: "process-lock" });
    ProcessLock = class _ProcessLock {
      lockPath;
      cliName;
      maxRetries;
      retryDelayMs;
      force;
      released = false;
      exitHandler;
      sigintHandler;
      sigtermHandler;
      constructor(options) {
        this.lockPath = options.lockPath;
        this.cliName = options.cliName;
        this.maxRetries = options.maxRetries ?? 3;
        this.retryDelayMs = options.retryDelayMs ?? 100;
        this.force = options.force ?? false;
      }
      /**
       * Acquire the lock. Throws CategorizedError if another live instance holds it.
       * Recovers stale locks from dead PIDs automatically.
       * Registers cleanup handlers on process exit/signals.
       */
      acquire() {
        (0, import_node_fs3.mkdirSync)((0, import_node_path3.dirname)(this.lockPath), { recursive: true });
        const content = formatLockContent(process.pid, this.cliName);
        for (let attempt = 0; attempt <= this.maxRetries; attempt++) {
          try {
            const fd = (0, import_node_fs3.openSync)(this.lockPath, "wx");
            (0, import_node_fs3.writeSync)(fd, content);
            (0, import_node_fs3.closeSync)(fd);
            this.registerCleanupHandlers();
            log.info({ pid: process.pid, lockPath: this.lockPath }, "Lock acquired");
            return;
          } catch (err) {
            const code = err.code;
            if (code !== "EEXIST") {
              throw catalogError("LOCK_IO_001", `Failed to create lock file: ${this.lockPath}`, {
                cause: err instanceof Error ? err : void 0
              });
            }
            const existing = _ProcessLock.readLockInfo(this.lockPath);
            if (!existing) {
              log.warn({ lockPath: this.lockPath }, "Removing corrupt lock file");
              safeUnlink(this.lockPath);
              continue;
            }
            if (isPidAlive(existing.pid)) {
              if (this.force) {
                log.warn({ pid: existing.pid, lockPath: this.lockPath }, "Force-overriding lock held by live process");
                safeUnlink(this.lockPath);
                continue;
              }
              throw catalogError("LOCK_HELD_001", `Another ${existing.cliName} instance is already running (PID ${existing.pid}, started ${existing.acquiredAt})`);
            }
            log.info({ stalePid: existing.pid, lockPath: this.lockPath }, "Recovering stale lock from dead process");
            safeUnlink(this.lockPath);
          }
          if (attempt < this.maxRetries) {
            sleepSync(this.retryDelayMs * (attempt + 1));
          }
        }
        throw catalogError("LOCK_RACE_001", `Failed to acquire lock after ${this.maxRetries} attempts: ${this.lockPath}`);
      }
      /**
       * Release the lock if this process still owns it.
       * Safe to call multiple times. Never throws.
       */
      release() {
        if (this.released) {
          return;
        }
        this.released = true;
        try {
          const info = _ProcessLock.readLockInfo(this.lockPath);
          if (!info) {
            return;
          }
          if (info.pid !== process.pid) {
            log.warn({ filePid: info.pid, currentPid: process.pid }, "Lock file PID does not match current process \u2014 skipping cleanup");
            return;
          }
          (0, import_node_fs3.unlinkSync)(this.lockPath);
          log.info({ pid: process.pid, lockPath: this.lockPath }, "Lock released");
        } catch (err) {
          log.warn({ err, lockPath: this.lockPath }, "Failed to release lock file \u2014 proceeding with shutdown");
        }
        this.deregisterCleanupHandlers();
      }
      /**
       * Read lock file info without acquiring. Returns null if no lock file or unparseable.
       */
      static readLockInfo(lockPath) {
        try {
          const raw = (0, import_node_fs3.readFileSync)(lockPath, "utf-8");
          return parseLockContent(raw);
        } catch {
          return null;
        }
      }
      /**
       * Check if a lock is held by a live process.
       * Returns LockInfo if held by a live process, null otherwise.
       */
      static probe(lockPath) {
        const info = _ProcessLock.readLockInfo(lockPath);
        if (!info) {
          return null;
        }
        return isPidAlive(info.pid) ? info : null;
      }
      registerCleanupHandlers() {
        this.exitHandler = () => this.release();
        this.sigintHandler = () => {
          this.release();
          process.exit(130);
        };
        this.sigtermHandler = () => {
          this.release();
          process.exit(143);
        };
        process.on("exit", this.exitHandler);
        process.on("SIGINT", this.sigintHandler);
        process.on("SIGTERM", this.sigtermHandler);
      }
      deregisterCleanupHandlers() {
        if (this.exitHandler) {
          process.removeListener("exit", this.exitHandler);
        }
        if (this.sigintHandler) {
          process.removeListener("SIGINT", this.sigintHandler);
        }
        if (this.sigtermHandler) {
          process.removeListener("SIGTERM", this.sigtermHandler);
        }
      }
    };
  }
});

