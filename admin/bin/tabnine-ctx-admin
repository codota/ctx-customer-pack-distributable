function acquireAdminLock(forceLock) {
  const lock = new ProcessLock({
    lockPath: adminLockPath(process.cwd()),
    cliName: "tabnine-ctx-admin",
    force: forceLock
  });
  lock.acquire();
}
function requireSettings(json) {
  const settings = loadSettings(process.cwd());
  if (!settings) {
    const msg = "No CTX settings found. Create .tabnine/ctx/ctx-settings.yaml:\n\n  CTX_API_URL: https://ctx.your-company.com\n  CTX_API_KEY: ctx_your_key_here\n  CTX_ADMIN_SECRET: your_admin_secret\n\nOr set CTX_API_URL, CTX_API_KEY, and CTX_ADMIN_SECRET environment variables.";
    if (json) {
      console.error(JSON.stringify({ error: msg }));
    } else {
      console.error(msg);
    }
    process.exit(1);
  }
  return settings;
}
function requireAdminSecret(settings, json) {
  const secret = settings?.adminSecret;
  if (!secret) {
    const msg = "Admin secret required. Set CTX_ADMIN_SECRET in .tabnine/ctx/ctx-settings.yaml or as an environment variable.";
    if (json) {
      console.error(JSON.stringify({ error: msg }));
    } else {
      console.error(msg);
    }
    process.exit(1);
  }
  return secret;
}
function resolveApiUrl(opts, settings) {
  const url = opts.apiUrl ?? settings?.apiUrl;
  if (!url) {
    console.error("API URL required. Use --api-url or set CTX_API_URL.");
    process.exit(1);
  }
  return url;
}
