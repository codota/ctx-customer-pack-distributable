var import_node_crypto, import_undici, AdminApiClient;
var init_admin_api_client = __esm({
  "admin/src/admin-api-client.ts"() {
    "use strict";
    import_node_crypto = require("node:crypto");
    import_undici = __toESM(require_undici(), 1);
    init_dist();
    AdminApiClient = class {
      apiUrl;
      apiKey;
      adminSecret;
      timeout;
      constructor(options) {
        this.apiUrl = options.apiUrl.replace(/\/$/, "");
        this.apiKey = options.apiKey;
        this.adminSecret = options.adminSecret;
        this.timeout = options.timeout ?? 3e4;
      }
      // ── No auth ──────────────────────────────────────────────
      async health() {
        return this.get("/api/health", "none");
      }
      // ── API key auth ─────────────────────────────────────────
      async ready() {
        return this.get("/api/ready", "api-key");
      }
      async configureAiSettings(body) {
        return this.put("/api/ai-settings", body, "api-key");
      }
      async createEmbeddingModel(body) {
        return this.post("/api/embedding-models", body, "api-key");
      }
      async listDataSources() {
        return this.get("/api/data-sources", "api-key");
      }
      async createDataSource(body) {
        return this.post("/api/data-sources", body, "api-key");
      }
      async getDataSource(id) {
        return this.get(`/api/data-sources/${id}`, "api-key");
      }
      async deleteDataSource(id, deleteEntities = true) {
        await this.del(`/api/data-sources/${id}?deleteEntities=${deleteEntities}`, "api-key");
      }
      async syncDataSource(id) {
        await this.post(`/api/data-sources/${id}/sync`, {}, "api-key");
      }
      async listEntities(params) {
        const qs = params?.limit ? `?limit=${params.limit}` : "";
        return this.get(`/api/entities${qs}`, "api-key");
      }
      async search(query) {
        return this.get(`/api/search?q=${encodeURIComponent(query)}`, "api-key");
      }
      async mcpInitialize() {
        return this.postRaw("/mcp", {
          jsonrpc: "2.0",
          id: 1,
          method: "initialize",
          params: {
            protocolVersion: "2024-11-05",
            capabilities: {},
            clientInfo: { name: "tabnine-ctx-admin", version: "0.1.0" }
          }
        }, "api-key");
      }
      async mcpListTools(sessionId) {
        return this.postRawWithHeaders("/mcp", {
          jsonrpc: "2.0",
          id: 2,
          method: "tools/list",
          params: {}
        }, "api-key", { "Mcp-Session-Id": sessionId });
      }
      async listAgentKinds() {
        return this.get("/api/agent-kinds", "api-key");
      }
      async createAgentKind(body) {
        return this.post("/api/agent-kinds", body, "api-key");
      }
      // ── Admin secret auth ────────────────────────────────────
      async createTenant(body) {
        return this.post("/api/admin/tenants", body, "admin-secret");
      }
      async listTenants() {
        return this.get("/api/admin/tenants", "admin-secret");
      }
      async createApiKey(tenantId, body) {
        return this.post(`/api/admin/tenants/${tenantId}/api-keys`, body, "admin-secret");
      }
      // ── Internal HTTP helpers ────────────────────────────────
      buildHeaders(auth, extra) {
        const headers = {
          "Content-Type": "application/json",
          "X-Request-ID": (0, import_node_crypto.randomUUID)(),
          ...extra
        };
        if (auth === "api-key") {
          if (!this.apiKey) {
            throw catalogError("ADMIN_AUTH_002", "API key required for this operation");
          }
          headers["x-api-key"] = this.apiKey;
        } else if (auth === "admin-secret") {
          if (!this.adminSecret) {
            throw catalogError("ADMIN_AUTH_001", "Admin secret required for this operation");
          }
          headers["x-admin-secret"] = this.adminSecret;
        }
        return headers;
      }
      async get(path, auth) {
        return this.doRequest("GET", path, void 0, auth);
      }
      async post(path, body, auth) {
        return this.doRequest("POST", path, body, auth);
      }
      async put(path, body, auth) {
        return this.doRequest("PUT", path, body, auth);
      }
      async del(path, auth) {
        await this.doRequest("DELETE", path, void 0, auth);
      }
      async postRaw(path, body, auth) {
        return this.doRequest("POST", path, body, auth);
      }
      async postRawWithHeaders(path, body, auth, extraHeaders) {
        return this.doRequest("POST", path, body, auth, extraHeaders);
      }
      async doRequest(method, path, body, auth, extraHeaders) {
        const url = `${this.apiUrl}${path}`;
        const headers = this.buildHeaders(auth, extraHeaders);
        try {
          const resp = await (0, import_undici.request)(url, {
            method,
            headers,
            body: body !== void 0 ? JSON.stringify(body) : void 0,
            headersTimeout: this.timeout,
            bodyTimeout: this.timeout
          });
          const text = await resp.body.text();
          if (resp.statusCode >= 400) {
            const { category, retryable } = classifyHttpStatus(resp.statusCode);
            const errorCode = resp.statusCode === 401 || resp.statusCode === 403 ? auth === "admin-secret" ? "ADMIN_AUTH_001" : "ADMIN_AUTH_002" : "ADMIN_CONN_001";
            throw catalogError(errorCode, `${method} ${path} returned ${resp.statusCode}`, {
              details: { statusCode: resp.statusCode, body: text.slice(0, 500), category, retryable }
            });
          }
          if (method === "DELETE" && (!text || text.trim() === "")) {
            return void 0;
          }
          return JSON.parse(text);
        } catch (err) {
          if (err instanceof CategorizedError) throw err;
          const classified = classifyNetworkError(err instanceof Error ? err : new Error(String(err)));
          throw catalogError("ADMIN_CONN_001", `Failed to connect to ${url}`, {
            cause: err instanceof Error ? err : void 0,
            details: { url, ...classified }
          });
        }
      }
    };
  }
});

