function loadSettings(baseDir) {
  const settingsPath = settingsFilePath(baseDir);
  if ((0, import_node_fs.existsSync)(settingsPath)) {
    try {
      const raw = (0, import_node_fs.readFileSync)(settingsPath, "utf-8");
      const parsed = (0, import_yaml2.parse)(raw);
      const apiUrl2 = parsed.CTX_API_URL || parsed.ctx_api_url || parsed.apiUrl;
      const apiKey2 = parsed.CTX_API_KEY || parsed.ctx_api_key || parsed.apiKey;
      const adminSecret = parsed.CTX_ADMIN_SECRET || parsed.ctx_admin_secret || parsed.adminSecret;
      if (apiUrl2 && apiKey2) {
        for (const [key, value] of Object.entries(parsed)) {
          if (typeof value === "string" && value && !process.env[key]) {
            process.env[key] = value;
          }
        }
        const { preset, config } = resolveDataVolume(parsed);
        return {
          apiUrl: apiUrl2,
          apiKey: apiKey2,
          adminSecret,
          projectName: parsed.PROJECT_NAME || parsed.project_name || parsed.projectName,
          dataVolume: config,
          dataVolumePreset: preset,
          all: parsed
        };
      }
    } catch {
    }
  }
  const apiUrl = process.env.CTX_API_URL;
  const apiKey = process.env.CTX_API_KEY;
  const adminSecretEnv = process.env.CTX_ADMIN_SECRET;
  if (apiUrl && apiKey) {
    return {
      apiUrl,
      apiKey,
      adminSecret: adminSecretEnv,
      dataVolume: DATA_VOLUME_PRESETS.standard,
      dataVolumePreset: "standard",
      all: {}
    };
  }
  return null;
}
function resolveDataVolume(parsed) {
  const presetName = parsed.DATA_VOLUME || parsed.data_volume || "standard";
  const preset = DATA_VOLUME_PRESETS[presetName] ?? DATA_VOLUME_PRESETS.standard;
  const config = { ...preset };
  const sinceDays = parsed.SINCE_DAYS || parsed.since_days;
  if (sinceDays) {
    config.sinceDays = parseInt(sinceDays, 10);
  }
  const events = parsed.EVENTS || parsed.events;
  if (events) {
    config.events = events.split(",").map((e) => e.trim());
  }
  const agentBudget = parsed.AGENT_BUDGET || parsed.agent_budget;
  if (agentBudget) {
    config.agentBudget = parseInt(agentBudget, 10);
  }
  return { preset: presetName, config };
}
