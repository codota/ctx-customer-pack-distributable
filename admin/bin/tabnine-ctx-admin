// admin/src/commands/status.ts
var status_exports = {};
__export(status_exports, {
  executeStatus: () => executeStatus
});
async function executeStatus(options) {
  const client = new AdminApiClient({ apiUrl: options.apiUrl, apiKey: options.apiKey });
  const result = {
    health: { status: "unknown", reachable: false },
    ready: null,
    entities: null,
    dataSources: null
  };
  try {
    const h = await client.health();
    result.health = { status: h.status ?? "ok", reachable: true };
  } catch {
    result.health = { status: "unreachable", reachable: false };
    return result;
  }
  try {
    const r = await client.ready();
    result.ready = { status: r.status ?? "ok", services: r.services };
  } catch {
    result.ready = { status: "error" };
  }
  try {
    const e = await client.listEntities({ limit: 1 });
    result.entities = { count: e.total ?? e.items.length };
  } catch {
    result.entities = { count: -1 };
  }
  try {
    const ds = await client.listDataSources();
    result.dataSources = { count: ds.items?.length ?? 0 };
  } catch {
    result.dataSources = { count: -1 };
  }
  return result;
}
var init_status = __esm({
  "admin/src/commands/status.ts"() {
    "use strict";
    init_admin_api_client();
  }
});

// admin/src/commands/smoke-test.ts
var smoke_test_exports = {};
__export(smoke_test_exports, {
  executeSmokeTest: () => executeSmokeTest
});
async function runPhase(name, fn) {
  const start = Date.now();
  try {
    const detail = await fn();
    return { name, status: "pass", detail, durationMs: Date.now() - start };
  } catch (err) {
    return {
      name,
      status: "fail",
      detail: err instanceof Error ? err.message : String(err),
      durationMs: Date.now() - start
    };
  }
}
function skipPhase(name, reason) {
  return { name, status: "skip", detail: reason, durationMs: 0 };
}
async function executeSmokeTest(options) {
  const tenantName = options.tenantName ?? "smoke-test";
  const testRepo = options.testRepo ?? "octocat/Hello-World";
  const [owner, repo] = testRepo.split("/");
  const tests = [];
  let tenantId;
  let tenantApiKey;
  let dataSourceId;
  const adminClient = new AdminApiClient({ apiUrl: options.apiUrl, adminSecret: options.adminSecret });
  tests.push(await runPhase("API Health", async () => {
    const h = await adminClient.health();
    return h.status ?? "ok";
  }));
  if (tests[tests.length - 1].status === "fail") {
    return buildResult(tests);
  }
  tests.push(await runPhase("Create Tenant", async () => {
    const t = await adminClient.createTenant({
      name: tenantName,
      slug: tenantName.toLowerCase().replace(/[^a-z0-9-]/g, "-")
    });
    tenantId = t.id;
    return `Tenant ID: ${t.id}`;
  }));
  if (!tenantId) {
    return buildResult(tests);
  }
  tests.push(await runPhase("Create API Key", async () => {
    const k = await adminClient.createApiKey(tenantId, { name: `${tenantName}-key` });
    tenantApiKey = k.key ?? k.apiKey;
    return tenantApiKey ? "API key created" : "API key response missing key field";
  }));
  if (!tenantApiKey) {
    return buildResult(tests, tenantId, tenantApiKey);
  }
  const tenantClient = new AdminApiClient({
    apiUrl: options.apiUrl,
    apiKey: tenantApiKey
  });
  tests.push(await runPhase("API Ready", async () => {
    const r = await tenantClient.ready();
    return r.status ?? "ok";
  }));
  if (options.anthropicApiKey) {
    tests.push(await runPhase("Configure AI", async () => {
      await tenantClient.configureAiSettings({
        provider: "anthropic_direct",
        apiKey: options.anthropicApiKey
      });
      return "Anthropic configured";
    }));
  } else {
    tests.push(skipPhase("Configure AI", "ANTHROPIC_API_KEY not set"));
  }
  if (options.openaiApiKey) {
    tests.push(await runPhase("Configure Embeddings", async () => {
      await tenantClient.createEmbeddingModel({
        name: "text-embedding-3-small",
        provider: "openai",
        model: "text-embedding-3-small",
        dimensions: 1536,
        apiKey: options.openaiApiKey,
        scope: "entities"
      });
      return "OpenAI embedding model configured";
    }));
  } else {
    tests.push(skipPhase("Configure Embeddings", "OPENAI_API_KEY not set"));
  }
  tests.push(await runPhase("Data Ingestion", async () => {
    const ds = await tenantClient.createDataSource({
      type: "github",
      name: `smoke-test-${owner}-${repo}`,
      config: { owner, repo, installationId: null }
    });
    dataSourceId = ds.id;
    for (let i = 0; i < 30; i++) {
      await sleep(1e4);
      const status = await tenantClient.getDataSource(dataSourceId);
      const syncStatus = status.lastSyncStatus ?? status.status ?? "unknown";
      if (syncStatus === "completed" || syncStatus === "success" || syncStatus === "synced") {
        return `Sync completed (${(i + 1) * 10}s)`;
      }
      if (syncStatus === "failed" || syncStatus === "error") {
        throw new Error(`Sync failed: ${syncStatus}`);
      }
    }
    throw new Error("Sync timed out after 300s");
  }));
  tests.push(await runPhase("Entity Query", async () => {
    const e = await tenantClient.listEntities({ limit: 10 });
    const count = e.total ?? e.items.length;
    if (count === 0) throw new Error("No entities found after ingestion");
    return `${count} entities found`;
  }));
  tests.push(await runPhase("Search", async () => {
    const s = await tenantClient.search(repo);
    return `${s.results.length} search results`;
  }));
  tests.push(await runPhase("MCP Tools", async () => {
    const init = await tenantClient.mcpInitialize();
    if (!init.result) throw new Error("MCP initialize failed");
    const sessionId = "smoke-test-session";
    const tools = await tenantClient.mcpListTools(sessionId);
    const toolCount = tools.result?.tools?.length ?? 0;
    return `${toolCount} MCP tools available`;
  }));
  if (!options.skipCleanup && dataSourceId) {
    tests.push(await runPhase("Cleanup", async () => {
      await tenantClient.deleteDataSource(dataSourceId, true);
      return "Test data source and entities deleted";
    }));
  } else if (options.skipCleanup) {
    tests.push(skipPhase("Cleanup", "Skipped (--skip-cleanup)"));
  }
  const result = buildResult(tests, tenantId, tenantApiKey);
  try {
    (0, import_node_fs4.mkdirSync)(adminDir(options.baseDir), { recursive: true });
    (0, import_node_fs4.writeFileSync)(adminSmokeTestResultPath(options.baseDir), JSON.stringify(result, null, 2));
  } catch {
  }
  return result;
}
function buildResult(tests, tenantId, tenantApiKey) {
  const passed = tests.filter((t) => t.status === "pass").length;
  const failed = tests.filter((t) => t.status === "fail").length;
  const skipped = tests.filter((t) => t.status === "skip").length;
  const durationMs = tests.reduce((sum, t) => sum + t.durationMs, 0);
  return {
    tests,
    tenant: tenantId ? { id: tenantId, apiKey: tenantApiKey ?? "" } : void 0,
    summary: { passed, failed, skipped, durationMs }
  };
}
function sleep(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}
