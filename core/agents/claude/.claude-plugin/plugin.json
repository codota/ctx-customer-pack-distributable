{
  "name": "ctx-customer-pack",
  "version": "1.0.0",
  "description": "Context Engine skills, MCP, and hooks for Claude Code",
  "skills": "./skills/",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/decision-context.py",
            "timeout": 3000
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/change-confidence.py",
            "timeout": 5000
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "ctx-cloud": {
      "command": "python3",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/scripts/ctx-mcp-proxy.py"
      ]
    }
  }
}